#recent-posts
  & > .recent-post-item:not(:first-child)
    margin-top: 28px

  & > .recent-post-item
    @extend .cardHover
    position: relative
    display: flex
    flex-direction: row
    align-items: stretch
    overflow: hidden
    min-height: 21em
    height: auto
    border: 1px solid var(--content-card-border)
    border-radius: var(--content-radius-lg)
    background: var(--content-surface-2)
    box-shadow: var(--content-card-shadow)
    transition: transform .35s ease, box-shadow .35s ease, border-color .35s ease

    +maxWidth768()
      flex-direction: column
      height: auto

    &:before
      position: absolute
      inset: 0
      background: var(--content-glow)
      opacity: .95
      pointer-events: none
      content: ''

    &:hover
      transform: translateY(-6px)
      border-color: rgba(73, 177, 245, .22)
      box-shadow: var(--content-card-shadow-hover)

      img.post_bg
        transform: scale(1.08)
        filter: saturate(1.08)

    &.ads-wrap
      display: block !important
      height: auto !important

    .post_cover
      position: relative
      overflow: hidden
      width: 46%
      height: 100%

      +maxWidth768()
        width: 100%
        height: 250px

      a
        display: block
        width: 100%
        height: 100%

        &:after
          position: absolute
          inset: 0
          background: linear-gradient(135deg, rgba(8, 15, 30, .04), rgba(8, 15, 30, .28))
          content: ''

      img.post_bg
        @extend .imgHover
        width: 100%
        height: 100%
        object-fit: cover
        transition: transform .75s ease, filter .45s ease

      &.right
        order: 1

        +maxWidth768()
          order: 0

    & >.recent-post-info
      position: relative
      z-index: 1
      display: flex
      flex-direction: column
      justify-content: center
      padding: 38px 40px
      width: 54%

      +maxWidth768()
        padding: 26px 22px 30px
        width: 100%

      &.no-cover
        width: 100%
        padding: 42px 40px

        +maxWidth768()
          padding: 30px 22px

      & > .article-title
        @extend .limit-more-line
        color: var(--content-title)
        font-size: 1.88em
        font-weight: 700
        line-height: 1.32
        letter-spacing: .02em
        transition: all .2s ease-in-out
        -webkit-line-clamp: 2

        +maxWidth768()
          font-size: 1.5em

        &:hover
          color: $text-hover

      & > .article-meta-wrap
        display: flex
        flex-wrap: wrap
        gap: 10px
        margin: 16px 0 18px
        color: var(--content-chip-text)
        font-size: 88%

        & > .post-meta-date
          cursor: default

        & > span
          display: inline-flex
          align-items: center
          min-height: 34px
          padding: 0 14px
          border: 1px solid rgba(73, 177, 245, .12)
          border-radius: 999px
          background: var(--content-chip-bg)

        .sticky
          color: $sticky-color

        i
          margin: 0 4px 0 0

        .fa-spinner
          margin: 0

        .article-meta-label
          if hexo-config('post_meta.page.label')
            padding-right: 4px
          else
            display: none

        .article-meta-separator
          display: none

        .article-meta-link
          margin: 0 4px

        if hexo-config('post_meta.page.date_format') == 'relative'
          time
            display: none

        a
          color: var(--content-chip-text)

          &:hover
            color: $text-hover
            text-decoration: none

      & > .content
        @extend .limit-more-line
        color: var(--content-copy)
        font-size: 1.02em
        line-height: 1.95
        -webkit-line-clamp: 3

      & > .article-actions
        margin-top: 22px

        .article-read-more
          display: inline-flex
          align-items: center
          gap: 10px
          padding: 11px 18px
          border-radius: 999px
          background: linear-gradient(135deg, $theme-color, lighten($theme-color, 22%))
          box-shadow: 0 16px 30px alpha($theme-color, .22)
          color: $white
          font-size: .95em
          font-weight: 600
          letter-spacing: .04em
          transition: transform .25s ease, box-shadow .25s ease

          &:hover
            transform: translateX(4px)
            box-shadow: 0 20px 38px alpha($theme-color, .28)
            color: $white

          i
            font-size: .9em

  +maxWidth768()
    & > .recent-post-item
      border-radius: 22px
